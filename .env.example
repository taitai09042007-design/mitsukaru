# ===== Firebase(設定すると再起動してもデータが消えなくなる) =====
# Firebase Realtime Database のURL
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/

# 認証方法はどちらか一方でOK
# 方法1: サービスアカウント鍵ファイルのパス(ローカル開発向け)
FIREBASE_KEY_PATH=../neruna/firebase-key.json
# 方法2: 鍵JSONの中身をそのまま1行で(Render等のホスティング向け)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# データを保存するRTDB内のルートパス(他システムと共用する場合の名前空間)
FIREBASE_ROOT=mitsukaru

# ===== 運用設定 =====
# 返却記録を保管担当だけに制限するPIN(空なら誰でも記録可能=デモモード)
STAFF_PIN=

# ローカル保存時のデータ置き場(Firebase未設定のときだけ使われる)
# DATA_DIR=/var/data
